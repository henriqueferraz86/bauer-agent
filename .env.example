# Bauer Agent — Variáveis de Ambiente
# Copie este arquivo para .env e preencha as chaves que precisar.
# Prioridade: variáveis do sistema > .env > config.yaml

# =============================================================================
# PROVIDER: OpenAI oficial (ChatGPT)
# =============================================================================
# config.yaml:
#   model:
#     provider: openai
#     name: gpt-4o-mini
#   openai:
#     host: https://api.openai.com
#
# Pegue sua chave em: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# =============================================================================
# PROVIDER: OpenRouter (200+ modelos — GPT, Claude, Gemini, Llama, etc.)
# =============================================================================
# Um único plano, acessa tudo. Recomendado se você quer flexibilidade.
# config.yaml:
#   model:
#     provider: openrouter
#     name: openai/gpt-4o-mini      # ou: anthropic/claude-haiku-3
#                                   #     google/gemini-flash-1.5
#                                   #     meta-llama/llama-3.3-70b-instruct
#
# Pegue sua chave em: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# =============================================================================
# PROVIDER: OpenCode Zen — modelos gratuitos, sem API key
# =============================================================================
# Endpoint: https://opencode.ai/zen/v1 (OpenAI-compatible)
# Modelos gratuitos: deepseek-v4-flash-free, mimo-v2.5-free,
#                   nemotron-3-super-free, big-pickle
# NÃO PRECISA de API key. Por padrão usa "public".
# Instale o opencode CLI: npm install -g opencode-ai
# Faça login:            opencode providers login
# Opcional — substitui a chave pública se você tiver uma conta premium:
# OPENCODE_API_KEY=seu-token-aqui

# =============================================================================
# PROVIDER: Ollama Cloud / Ollama remoto protegido
# =============================================================================
# Para Ollama Cloud: https://ollama.com/settings
# Para Ollama local protegido por proxy (sem autenticação: deixe vazio)
# OLLAMA_API_KEY=

# =============================================================================
# PROVIDER: Custom / endpoint OpenAI-compatible
# =============================================================================
# Para LM Studio, vLLM, llama.cpp, ou qualquer servidor compatível.
# config.yaml:
#   model:
#     provider: custom
#     name: seu-modelo
#   openai:
#     host: http://localhost:1234   # ou https://seu-servidor.com
#
# Chave opcional (deixe vazio se o servidor não exigir auth):
# OPENAI_API_KEY=

# =============================================================================
# BAUER SERVE — autenticação da API REST
# =============================================================================
# Protege os endpoints do bauer serve com Bearer token.
# Gere uma chave: openssl rand -hex 32
# BAUER_SERVE_API_KEY=

# =============================================================================
# BAUER GATEWAY — canais de chat (Telegram, Discord)
# =============================================================================
# Setup guiado: bauer gateway init
#
# Telegram: crie um bot com o @BotFather e cole o token aqui.
# TELEGRAM_BOT_TOKEN=123456789:AAF...
#
# Discord: https://discord.com/developers/applications → Bot → Token.
# Habilite o intent MESSAGE_CONTENT na aba Bot do Developer Portal.
# DISCORD_BOT_TOKEN=MTIz...

# =============================================================================
# GROQ (rápido, gratuito com limites)
# =============================================================================
# config.yaml:
#   model:
#     provider: openai
#     name: llama-3.3-70b-versatile
#   openai:
#     host: https://api.groq.com/openai
#
# Pegue sua chave em: https://console.groq.com/keys
# OPENAI_API_KEY=gsk_...
